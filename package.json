{
  "name": "blog-pessoal",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vinext dev",
    "build": "vinext build",
    "start": "vinext start",
    "typecheck": "tsc --noEmit",
    "lint": "oxlint .",
    "lint:fix": "oxlint . --fix",
    "format": "oxfmt --check .",
    "format:fix": "oxfmt .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:smoke": "vitest run --config vitest.smoke.config.ts",
    "check": "yarn run lint && yarn run format && yarn run typecheck && yarn run test",
    "prepare": "husky",
    "update:vinext": "yarn up vinext@latest",
    "update:all": "yarn up vinext@latest vite@latest @vitejs/plugin-react@latest tailwindcss@latest @tailwindcss/vite@latest @tailwindcss/postcss@latest marked@latest shiki@latest react@latest react-dom@latest"
  },
  "dependencies": {
    "@tailwindcss/postcss": "^4.3.0",
    "@tailwindcss/vite": "^4.3.0",
    "@vitejs/plugin-react": "^6.0.1",
    "marked": "^18.0.3",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "shiki": "^4.0.2",
    "tailwindcss": "^4.3.0",
    "vinext": "^0.0.49",
    "vite": "^8.0.12"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "^1.36.3",
    "@cloudflare/workers-types": "^4.20260511.1",
    "@types/node": "^25.7.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-rsc": "^0.5.26",
    "@vitest/coverage-v8": "^4.1.6",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.4",
    "oxfmt": "^0.49.0",
    "oxlint": "^1.64.0",
    "react-server-dom-webpack": "^19.2.6",
    "typescript": "^6.0.3",
    "vitest": "^4.1.6",
    "wrangler": "^4.90.0"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx}": [
      "oxlint --fix",
      "oxfmt"
    ],
    "*.{json,md,css}": [
      "oxfmt"
    ]
  },
  "packageManager": "yarn@4.14.1+sha512.64df448055b2d37ba269d7db535a469b8da93f8ef1140c25fd7a83c00a8fbaacb214ca0e02553b92a2c54cef78bb67d0b4817fab02001df0e24fac0faccc3b42"
}
